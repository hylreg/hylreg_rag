# OpenAI API密钥
# 从 https://platform.openai.com/account/api-keys 获取
OPENAI_API_KEY=your_openai_api_key_here

# 可选：OpenAI API基础URL（对于某些地区可能需要）
# OPENAI_API_BASE=https://api.openai.com/v1

# 检索参数
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_RETRIEVAL_K=4

# 向量库持久化目录
RAG_VECTORSTORE_DIR=data/vectorstore
RAG_AUTO_PERSIST=true

# API上传限制
API_MAX_UPLOAD_SIZE_MB=20
API_ALLOWED_EXTENSIONS=.pdf,.txt,.docx
