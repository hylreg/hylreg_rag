# OpenAI API密钥
# 从 https://platform.openai.com/account/api-keys 获取
OPENAI_API_KEY=your_openai_api_key_here

# 可选：OpenAI API基础URL（对于某些地区可能需要）
# OPENAI_API_BASE=https://api.openai.com/v1

# 检索参数
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_RETRIEVAL_K=4

# 向量库持久化目录
RAG_VECTORSTORE_DIR=data/vectorstore
RAG_AUTO_PERSIST=true

# API上传限制
API_MAX_UPLOAD_SIZE_MB=20
API_ALLOWED_EXTENSIONS=.pdf,.txt,.docx

# API访问控制（可选）
# 设置后将启用 Bearer Token 鉴权
# API_AUTH_TOKEN=replace_with_a_strong_token

# API限流（每IP每分钟，<=0 表示关闭）
API_RATE_LIMIT_PER_MINUTE=60

# 旧路由弃用的 Sunset 时间（RFC1123 格式）
API_LEGACY_SUNSET=Wed, 31 Dec 2026 23:59:59 GMT
